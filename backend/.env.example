PORT=4000
NODE_ENV=development
ALLOWED_ORIGINS=*

# Keep true for local testing. Set false for stricter production behavior.
ALLOW_UNAUTHENTICATED_DEV=true

# Firebase Admin setup option 1: path to service account file
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# Firebase Admin setup option 2: paste JSON as one-line string instead of file
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Optional fallback project id
FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
